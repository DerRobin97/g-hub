# ─────────────────────────────────────────────────────────────
# G-Hub — Environment-Variablen (Vorlage)
# Kopiere diese Datei zu .env und fülle die Werte. NIE echte
# Secrets committen. In Produktion: Railway Variables verwenden.
# ─────────────────────────────────────────────────────────────

# --- Backend: Core ---
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# --- Datenbank (PostgreSQL) ---
DATABASE_URL=postgresql://ghub:ghub@localhost:5434/ghub?schema=public

# --- Redis (BullMQ Jobs) ---
REDIS_URL=redis://localhost:6379

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Verschlüsselung für gespeicherte Integration-Tokens ---
TOKEN_ENCRYPTION_KEY=change-me-32-byte-hex

# --- Meta (Instagram + Facebook) ---
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/integrations/meta/callback
META_WEBHOOK_VERIFY_TOKEN=

# --- Google OAuth (Client-ID + Secret aus der Google Cloud Console) ---
# Dieselbe OAuth-Client-ID kann Login UND Ads/GA4 bedienen, solange in der
# Console BEIDE Redirect-URIs als "Autorisierte Weiterleitungs-URIs" stehen.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Login ("Sign in with Google") — Auth-Callback:
# LOKAL: direkt aufs Backend. PRODUKTION (Railway): MUSS auf die FRONTEND-Domain
# zeigen, damit der OAuth-Callback über den /api-Proxy läuft und die Auth-Cookies
# first-party gesetzt werden (sonst Login-Rücksprung, da up.railway.app ein
# Public-Suffix ist → getrennte Sites). Prod-Wert z. B.:
#   https://g-hub-frontend-production.up.railway.app/api/auth/google/callback
# Dieselbe URL zusätzlich in der Google-Cloud-Console als Redirect-URI eintragen.
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Integrationen (Google Ads / GA4) — separater Callback + Developer-Token:
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=

# --- KI (Anthropic / Claude) ---
ANTHROPIC_API_KEY=
# Optional: Modell überschreiben (Default: claude-3-5-haiku-latest).
ANTHROPIC_MODEL=

# --- Object Storage (S3-kompatibel) ---
# Lokal: MinIO aus docker-compose (Defaults unten). Produktiv (Railway):
# Cloudflare R2 / AWS S3 — nur diese Werte tauschen, Code bleibt gleich.
# STORAGE_PUBLIC_ENDPOINT = vom Browser erreichbare URL (presigned Up-/Download).
STORAGE_ENDPOINT=http://localhost:9002
STORAGE_PUBLIC_ENDPOINT=http://localhost:9002
STORAGE_REGION=us-east-1
STORAGE_BUCKET=g-hub-assets
STORAGE_ACCESS_KEY_ID=ghubminio
STORAGE_SECRET_ACCESS_KEY=ghubminio
STORAGE_FORCE_PATH_STYLE=true

# --- Frontend (Vite) ---
# LOKAL: Vite-Proxy übernimmt /api (frontend/.env nicht nötig). PRODUKTION
# (Railway, Service "frontend"): VITE_API_URL=/api  (relativ → Browser ruft die
# Frontend-Domain auf; server.mjs proxyt /api ans Backend → first-party Cookies).
VITE_API_URL=http://localhost:3000/api

# --- Frontend-Proxy (NUR Produktion, Railway-Service "frontend", Laufzeit) ---
# Ziel-Backend für den /api-Reverse-Proxy in server.mjs. OHNE /api-Pfad.
# z. B. https://g-hub-production.up.railway.app
BACKEND_ORIGIN=

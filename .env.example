# ─────────────────────────────────────────────────────────────
# G-Hub — Environment-Variablen (Vorlage)
# Kopiere diese Datei zu .env und fülle die Werte. NIE echte
# Secrets committen. In Produktion: Railway Variables verwenden.
# ─────────────────────────────────────────────────────────────

# --- Backend: Core ---
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# --- Datenbank (PostgreSQL) ---
DATABASE_URL=postgresql://ghub:ghub@localhost:5434/ghub?schema=public

# --- Redis (BullMQ Jobs) ---
REDIS_URL=redis://localhost:6379

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Verschlüsselung für gespeicherte Integration-Tokens ---
TOKEN_ENCRYPTION_KEY=change-me-32-byte-hex

# --- Meta (Instagram + Facebook) ---
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/integrations/meta/callback
META_WEBHOOK_VERIFY_TOKEN=

# --- Google OAuth (Client-ID + Secret aus der Google Cloud Console) ---
# Dieselbe OAuth-Client-ID kann Login UND Ads/GA4 bedienen, solange in der
# Console BEIDE Redirect-URIs als "Autorisierte Weiterleitungs-URIs" stehen.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Login ("Sign in with Google") — Auth-Callback:
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Integrationen (Google Ads / GA4) — separater Callback + Developer-Token:
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=

# --- KI (Anthropic / Claude) ---
ANTHROPIC_API_KEY=

# --- Object Storage (S3-kompatibel, z. B. Cloudflare R2) ---
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=g-hub-assets
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:3000/api

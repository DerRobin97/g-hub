// G-Hub — Prisma-Schema
// Aufbau schrittweise entlang Bauplan §4. Aktueller Stand (Phase 0):
// Mandanten/Nutzer/Rollen + Appearance. Weitere Entitäten folgen je Phase.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// §4.1 Mandanten / Nutzer / Rollen
// ─────────────────────────────────────────────────────────────

enum Role {
  owner
  admin
  content_lead
  designer
  social_manager
  analyst
  member
}

enum Theme {
  light
  gray
  dark
}

model Workspace {
  id            String       @id @default(uuid())
  name          String
  slug          String       @unique
  plan          String       @default("free")
  brandingLogo  String?      @map("branding_logo")
  brandingColor String?      @map("branding_color")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  memberships Membership[]
  tasks       Task[]
  projects    Project[]
  campaigns   Campaign[]

  @@map("workspaces")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  // Optional: OAuth-Nutzer (Google) haben kein Passwort.
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  avatarUrl    String?  @map("avatar_url")
  gradient     String?
  phone        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships     Membership[]
  appearance      AppearancePref?
  tasksCreated    Task[]         @relation("TaskCreatedBy")
  taskAssignments TaskAssignee[]
  projectsLed     Project[]      @relation("ProjectLead")
  projectsCreated Project[]      @relation("ProjectCreatedBy")
  projectMemberships     ProjectMember[]
  projectTaskMemberships ProjectTaskMember[]
  campaignsCreated       Campaign[]         @relation("CampaignCreatedBy")

  @@map("users")
}

model Membership {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  workspaceId String    @map("workspace_id")
  role        Role      @default(member)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("memberships")
}

// §4.1 AppearancePref (pro User) — heute localStorage, künftig DB + lokaler Cache
model AppearancePref {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  theme        Theme    @default(light)
  accent       String   @default("gruen")
  customAccent String?  @map("custom_accent")
  corners      String   @default("md")
  webLayout    String   @default("full") @map("web_layout")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("appearance_prefs")
}

// ─────────────────────────────────────────────────────────────
// §4.6 Aufgaben — EINE konsolidierte Task-Entität (persönlich + Team).
// „Meine Aufgaben" = Filter assignees enthält mich; „Team" = alle des Workspace.
// ─────────────────────────────────────────────────────────────

enum TaskStatus {
  offen
  arbeit
  erledigt
}

enum TaskPriority {
  high
  med
  low
}

enum TaskRole {
  lead
  collab
}

model Task {
  id          String       @id @default(uuid())
  workspaceId String       @map("workspace_id")
  title       String
  description String?
  // Freier Projektname, bis die Projekt-Entität existiert (§4.5).
  projectText String?      @map("project_text")
  dueDate     DateTime?    @map("due_date")
  // Anzeige-Label aus dem Prototyp (z. B. „Heute"); optional zusätzlich zum Datum.
  dueLabel    String?      @map("due_label")
  time        String?
  priority    TaskPriority @default(med)
  status      TaskStatus   @default(offen)
  role        TaskRole     @default(lead)
  tag         String?
  createdById String       @map("created_by_id")
  completedAt DateTime?    @map("completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User                @relation("TaskCreatedBy", fields: [createdById], references: [id])
  assignees TaskAssignee[]
  checklist TaskChecklistItem[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("tasks")
}

model TaskAssignee {
  taskId String @map("task_id")
  userId String @map("user_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

model TaskChecklistItem {
  id       String  @id @default(uuid())
  taskId   String  @map("task_id")
  title    String
  done     Boolean @default(false)
  position Int     @default(0)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_checklist_items")
}

// ─────────────────────────────────────────────────────────────
// §4.5 Projektmanager — Projekt → Phasen → Projekt-Aufgaben.
// ─────────────────────────────────────────────────────────────

enum ProjectTaskPriority {
  high
  mid
  low
}

model Project {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  kind        String?
  dueDate     DateTime? @map("due_date")
  dueLabel    String?   @map("due_label")
  leadId      String?   @map("lead_id")
  budgetText  String?   @map("budget_text")
  description String?
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      User?           @relation("ProjectLead", fields: [leadId], references: [id])
  createdBy User            @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  members   ProjectMember[]
  phases    Phase[]

  @@index([workspaceId])
  @@map("projects")
}

model ProjectMember {
  projectId String @map("project_id")
  userId    String @map("user_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model Phase {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  name      String
  order     Int    @default(0)

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   ProjectTask[]

  @@index([projectId])
  @@map("phases")
}

model ProjectTask {
  id          String              @id @default(uuid())
  phaseId     String              @map("phase_id")
  title       String
  description String?
  done        Boolean             @default(false)
  completedAt DateTime?           @map("completed_at")
  dueDate     DateTime?           @map("due_date")
  dueLabel    String?             @map("due_label")
  priority    ProjectTaskPriority @default(mid)
  // Verknüpfte Links/Referenzen (URL oder freie Beschreibung) — wie im Prototyp.
  links       String[]
  order       Int                 @default(0)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  phase   Phase               @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  members ProjectTaskMember[]

  @@index([phaseId])
  @@map("project_tasks")
}

model ProjectTaskMember {
  taskId String @map("task_id")
  userId String @map("user_id")

  task ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
  @@map("project_task_members")
}

// ─────────────────────────────────────────────────────────────
// §4.4 Kampagnen — Kampagne → Maßnahmen → Rabattaktionen.
// ─────────────────────────────────────────────────────────────

// Status für Kampagnen und Maßnahmen (deckt sich mit StatusTag im Frontend).
enum CampaignStatus {
  live
  review
  draft
}

// Maßnahmen-Art (Prototyp-Labels: Organisch|Promotion|Paid|Code).
enum MeasureType {
  organisch
  promotion
  paid
  code
}

// Rabatt-Art (Prototyp-Labels: Prozent|2 für 1|Versand|Code).
enum DiscountType {
  prozent
  zwei_fuer_eins
  versand
  code
}

model Campaign {
  id          String         @id @default(uuid())
  workspaceId String         @map("workspace_id")
  name        String
  status      CampaignStatus @default(draft)
  // Kanal-Schlüssel (instagram, facebook, …) — wie CHANNELS in @g-hub/shared.
  channels    String[]
  budget      Int            @default(0)
  spent       Int            @default(0)
  reach       Int            @default(0)
  kpiText     String?        @map("kpi_text")
  startDate   DateTime?      @map("start_date")
  endDate     DateTime?      @map("end_date")
  // Anzeige-Label des Zeitraums (z. B. „01.–30. Jun"), analog dueLabel.
  zeitraum    String?
  // Anzeige-Label der Fälligkeit (Prototyp `due`, z. B. „12. Jun").
  dueLabel    String?        @map("due_label")
  // Akzentfarbe der Kampagne (z. B. „var(--ch-instagram)").
  color       String?
  createdById String         @map("created_by_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("CampaignCreatedBy", fields: [createdById], references: [id])
  measures  Measure[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("campaigns")
}

model Measure {
  id         String         @id @default(uuid())
  campaignId String         @map("campaign_id")
  name       String
  type       MeasureType    @default(organisch)
  status     CampaignStatus @default(draft)
  // Fortschritt 0..1.
  progress   Float          @default(0)
  postsCount Int            @default(0) @map("posts_count")
  order      Int            @default(0)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  discounts Discount[]

  @@index([campaignId])
  @@map("measures")
}

model Discount {
  id        String       @id @default(uuid())
  measureId String       @map("measure_id")
  name      String
  type      DiscountType @default(prozent)
  // Anzeige-Wert (z. B. „−20 %", „2:1", „0 €").
  value     String?
  code      String?
  startDate DateTime?    @map("start_date")
  endDate   DateTime?    @map("end_date")
  zeitraum  String?
  redeemed  Int          @default(0)
  limit     Int          @default(0)
  order     Int          @default(0)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  measure Measure @relation(fields: [measureId], references: [id], onDelete: Cascade)

  @@index([measureId])
  @@map("discounts")
}
